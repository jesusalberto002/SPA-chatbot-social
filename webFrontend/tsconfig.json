{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",  // <--- ADD THIS LINE
    "moduleResolution": "bundler",
    // It's also good practice to add a target, though not directly related to this error
    "target": "esnext", // <--- GOOD TO ADD THIS TOO
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true, // Often goes with noEmit
    "resolveJsonModule": true // If you plan to import JSON files
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx"
  ],
  "exclude": [
    "node_modules"
  ]
}